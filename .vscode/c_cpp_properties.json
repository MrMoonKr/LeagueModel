{
  "version": 4,
  "configurations": [
    {
      "name": "x64-Debug",
      "compilerPath": "cl.exe",
      "intelliSenseMode": "windows-msvc-x64",
      "cStandard": "c17",
      "cppStandard": "c++20",
      "defines": [
        "_DEBUG",
        "UNICODE",
        "_UNICODE",
        "WIN32",
        "_WINDOWS",
        "WIN32_LEAN_AND_MEAN",
        "NOMINMAX",
        "SOKOL_GLCORE33",
        "SOKOL_IMGUI",
        "SPEK_WINDOWS"
      ],
      "includePath": [
        "${workspaceFolder}/src",
        "${workspaceFolder}/ext",
        "${workspaceFolder}/build/_deps/glad-build/include",
        "${workspaceFolder}/build/_deps/glfw-src/include",
        "${workspaceFolder}/ext/sokol/inc",
        "${workspaceFolder}/ext/sokol/ext/sokol",
        "${workspaceFolder}/ext/sokol/ext/sokol/util",
        "${workspaceFolder}/ext/sokol/ext/imgui",
        "${workspaceFolder}/ext/leaguelib/inc",
        "${workspaceFolder}/ext/leaguelib/ext",
        "${workspaceFolder}/ext/leaguelib/ext/glm",
        "${workspaceFolder}/ext/leaguelib/ext/spekfile/inc",
        "${workspaceFolder}/ext/leaguelib/ext/spekfile/ext/spekutil/inc",
        "${workspaceFolder}/ext/leaguelib/ext/zlib",
        "${workspaceFolder}/ext/leaguelib/ext/zstd/lib",
        "${workspaceFolder}/build/ext/leaguelib/ext/zlib"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/src",
          "${workspaceFolder}/ext",
          "${workspaceFolder}/build/_deps/glad-build/include",
          "${workspaceFolder}/build/_deps/glfw-src/include",
          "${workspaceFolder}/ext/sokol/inc",
          "${workspaceFolder}/ext/sokol/ext/sokol",
          "${workspaceFolder}/ext/sokol/ext/sokol/util",
          "${workspaceFolder}/ext/sokol/ext/imgui",
          "${workspaceFolder}/ext/leaguelib/inc",
          "${workspaceFolder}/ext/leaguelib/ext",
          "${workspaceFolder}/build/ext/leaguelib/ext/zlib"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    },
    {
      "name": "x64-Release",
      "compilerPath": "cl.exe",
      "intelliSenseMode": "windows-msvc-x64",
      "cStandard": "c17",
      "cppStandard": "c++20",
      "defines": [
        "NDEBUG",
        "UNICODE",
        "_UNICODE",
        "WIN32",
        "_WINDOWS",
        "WIN32_LEAN_AND_MEAN",
        "NOMINMAX",
        "SOKOL_GLCORE33",
        "SOKOL_IMGUI",
        "SPEK_WINDOWS"
      ],
      "includePath": [
        "${workspaceFolder}/src",
        "${workspaceFolder}/ext",
        "${workspaceFolder}/build/_deps/glad-build/include",
        "${workspaceFolder}/build/_deps/glfw-src/include",
        "${workspaceFolder}/ext/sokol/inc",
        "${workspaceFolder}/ext/sokol/ext/sokol",
        "${workspaceFolder}/ext/sokol/ext/sokol/util",
        "${workspaceFolder}/ext/sokol/ext/imgui",
        "${workspaceFolder}/ext/leaguelib/inc",
        "${workspaceFolder}/ext/leaguelib/ext",
        "${workspaceFolder}/ext/leaguelib/ext/glm",
        "${workspaceFolder}/ext/leaguelib/ext/spekfile/inc",
        "${workspaceFolder}/ext/leaguelib/ext/spekfile/ext/spekutil/inc",
        "${workspaceFolder}/ext/leaguelib/ext/zlib",
        "${workspaceFolder}/ext/leaguelib/ext/zstd/lib",
        "${workspaceFolder}/build/ext/leaguelib/ext/zlib"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/src",
          "${workspaceFolder}/ext",
          "${workspaceFolder}/build/_deps/glad-build/include",
          "${workspaceFolder}/build/_deps/glfw-src/include",
          "${workspaceFolder}/ext/sokol/inc",
          "${workspaceFolder}/ext/sokol/ext/sokol",
          "${workspaceFolder}/ext/sokol/ext/sokol/util",
          "${workspaceFolder}/ext/sokol/ext/imgui",
          "${workspaceFolder}/ext/leaguelib/inc",
          "${workspaceFolder}/ext/leaguelib/ext",
          "${workspaceFolder}/build/ext/leaguelib/ext/zlib"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
