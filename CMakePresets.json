{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-x64",
      "displayName": "Visual Studio 2022 x64",
      "description": "Configure with the Visual Studio 2022 generator for x64. Uses build/ for intermediates and bin/<config>/ for final executables.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/bin/$<CONFIG>",
        "CMAKE_PDB_OUTPUT_DIRECTORY": "${sourceDir}/bin/$<CONFIG>"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Build Debug",
      "configurePreset": "vs2022-x64",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "displayName": "Build Release",
      "configurePreset": "vs2022-x64",
      "configuration": "Release"
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Build RelWithDebInfo",
      "configurePreset": "vs2022-x64",
      "configuration": "RelWithDebInfo"
    }
  ]
}
